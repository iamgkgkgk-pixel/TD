# ============================================================
# Unity .gitignore — 适配 AetheraSurvivors 项目
# 
# 说明：
#   1. 排除Unity生成的临时文件和构建产物
#   2. 排除操作系统特定文件
#   3. 排除IDE配置（但保留.vsconfig）
#   4. 保留.meta文件（Unity需要）
#   5. 配置Git LFS追踪大文件
#
# 对应交互：阶段二 #73
# ============================================================

# ========================================
# Unity 生成文件（递归匹配所有子目录）
# ========================================
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/

# MemoryCaptures
**/[Mm]emoryCaptures/

# Asset Import 缓存
**/Assets/AssetStoreTools*

# TextToolDatas (Unity 微信SDK生成)
**/TextToolDatas/


# Autogenerated Crash reports
sysinfo.txt
crashlytics-build.properties

# ========================================
# Unity 构建输出
# ========================================
*.apk
*.aab
*.unitypackage
*.app

# WebGL 构建
/WebGL_Build/

# 微信小游戏导出
# 注意：minigame目录可能需要git管理，但排除node_modules
**/minigame/node_modules/
**/minigame/.cache/

# ========================================
# IDE / 编辑器
# ========================================

# Visual Studio
.vs/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj

# JetBrains Rider
.idea/
*.iml

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# ========================================
# 操作系统
# ========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini

# Linux
*~

# ========================================
# 其他
# ========================================

# NPM (如果有Node.js工具)
node_modules/
npm-debug.log

# Python (如果有辅助脚本)
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
*.egg

# 压缩文件（大文件不入库，用Git LFS或CDN）
# *.zip
# *.rar
# *.7z

# 纹理源文件（PSD/PSB太大，用Git LFS）
# *.psd
# *.psb

# 视频文件
*.mp4
*.avi
*.mov
*.wmv

# ========================================
# 特定排除 — AetheraSurvivors 项目
# ========================================

# 技术原型导出（不需要入库）
/Unity/Wegame/

# 本地测试用存档
/TestSaves/

# AI生成的中间文件
/AI_Generated_Temp/

# CodeBuddy 工具缓存
.codebuddy/
